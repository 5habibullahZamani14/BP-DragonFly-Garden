PORT=5000
HOST=0.0.0.0

# Resend API Key — get a free key at https://resend.com
# Used to send password-reset emails to the manager.
RESEND_API_KEY=

# The "from" email address shown in reset emails.
# With a free Resend account, use: onboarding@resend.dev
# With a custom domain, use e.g.: system@dragonflygarden.com
EMAIL_FROM=onboarding@resend.dev

# Google Gemini API Key — get a free key at https://makersuite.google.com/app/apikey
# Used for AI-powered feedback analysis in the manager dashboard.
# This is optional - if not set, the system will fall back to rule-based analysis.
GEMINI_API_KEY=
