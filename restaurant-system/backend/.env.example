PORT=5000
HOST=0.0.0.0

# Resend API Key — get a free key at https://resend.com
# Used to send password-reset emails to the manager.
RESEND_API_KEY=

# The "from" email address shown in reset emails.
# With a free Resend account, use: onboarding@resend.dev
# With a custom domain, use e.g.: system@dragonflygarden.com
EMAIL_FROM=onboarding@resend.dev

# Groq API Key — get a free key at https://console.groq.com/keys
# Used for AI-powered feedback analysis in the manager dashboard.
# This is optional - if not set, the system will fall back to rule-based analysis.
GROQ_API_KEY=

# REQUIRED: a strong secret used to sign JWTs. Generate one securely (eg. `openssl rand -base64 32`).
JWT_SECRET=replace_with_secure_random_string

# CORS origins (comma-separated). In production set to your frontend origin(s).
# When the Pi serves the built frontend, the browser origin is http://10.42.0.1:5000.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.example,http://10.42.0.1:5000

# If set to 1, server runs in Vite dev passthrough mode (less restrictive CORS)
VITE_DEV_MODE=0

# Path to sqlite DB (optional override)
DATABASE_PATH=./data/database.sqlite

# Notes:
# - Never commit a real secret to version control. Keep .env in .gitignore.
# - To generate a secure secret: `openssl rand -base64 32` (or use a secrets manager).
